# Calendly: use separate URLs per session type, or one for both
# NEXT_PUBLIC_CALENDLY_SCHEDULING_URL is used as fallback if the others are not set
NEXT_PUBLIC_CALENDLY_SCHEDULING_URL="https://calendly.com/your-username"
NEXT_PUBLIC_CALENDLY_CONSULTATION_URL="https://calendly.com/your-username/15min"
NEXT_PUBLIC_CALENDLY_SESSION_URL="https://calendly.com/your-username/45min"
